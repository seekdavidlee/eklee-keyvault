# Bicep ignore file
# Files and patterns to ignore when building Bicep templates

# Scripts
*.ps1
*.sh
*.bash

# Documentation
*.md
README*
CHANGELOG*
LICENSE*

# IDE and editor files
.vscode/
.vs/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Build outputs
*.log
*.tmp

# Parameter files are included in deployment
# *.parameters.json

# Test files
*test*
*spec*
